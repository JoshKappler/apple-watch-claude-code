# How the agent authenticates to Anthropic:
#   subscription = use the Claude Code login already on this Mac (your Claude Max
#                  plan, from the keychain). No API key needed. This is the default.
#   apikey       = use ANTHROPIC_API_KEY below.
PINCH_AUTH=subscription

# Only needed when PINCH_AUTH=apikey. Leave blank to use your Claude Max subscription.
ANTHROPIC_API_KEY=

# Bearer token the watch/simulator must present to connect.
# Generate a strong random one with: node infra/scripts/gen-token.mjs
# (or run ./setup.sh, which fills this in for you). Treat it like an SSH key.
PINCH_TOKEN=

# WebSocket server port. Path is always /ws.
PORT=8787

# WHICH REPOS THE WATCH CAN OPEN. Set at least one of the two below.
#
# Recommended: point Pinch at a parent folder and it lists every child repo,
# recency-sorted, recomputed each time you open the picker on the watch (so newly
# cloned repos just show up — no restart). The agent cds into whichever you pick.
PINCH_PROJECT_ROOTS=/abs/path/to/projects
#
# Optional explicit allowlist of individual repo roots (comma-separated). Use this
# instead of, or in addition to, PINCH_PROJECT_ROOTS. Paths outside every root here
# AND every scan root above are rejected.
PINCH_PROJECTS=

# 1 = scripted mock agent (no SDK, no API key). 0 = real Claude Agent SDK.
PINCH_MOCK=0

# Model id passed to the SDK.
PINCH_MODEL=claude-opus-4-8

# pino log level: trace|debug|info|warn|error|fatal
LOG_LEVEL=info
